{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/report/layout,_N_T_/report/extract/layout,_N_T_/report/extract/page,_N_T_/report/extract"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/report/extract/__PAGE__",
    "/report/extract",
    "/report",
    "/_index",
    "/_head"
  ]
}